[Unit]
Description=Back up Pi Klydo Clock community database
After=piclock-community.service

[Service]
Type=oneshot
User=piclock-community
Group=piclock-community
WorkingDirectory=/opt/pi-clock-community/current
ExecStart=/opt/pi-clock-community/venv/bin/python -m community.backup --data /var/lib/pi-clock-community --keep-days 14
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/pi-clock-community
